<idea-plugin>
    <id>com.example.ideaai</id>
    <name>Idea AI Helper</name>
    <vendor email="vladislav@example.com">Vladislav</vendor>

    <description><![CDATA[
        Starter plugin for IntelliJ IDEA Ultimate with Kotlin.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <actions>
        <action id="com.example.ideaai.actions.HelloAction"
                class="com.example.ideaai.actions.HelloAction"
                text="Idea AI: Hello"
                description="Shows hello from plugin">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
